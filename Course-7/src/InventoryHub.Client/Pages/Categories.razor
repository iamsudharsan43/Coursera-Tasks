@page "/categories"
@inject CategoryService CategoryService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Categories - InventoryHub</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Categories</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudGrid>
        <MudItem xs="12" sm="8" md="10">
            <MudTextField @bind-Value="_searchString"
                          Label="Search"
                          Placeholder="Search categories"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          DebounceInterval="300"
                          OnDebounceIntervalElapsed="OnSearchChanged" />
        </MudItem>
        <MudItem xs="12" sm="4" md="2" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       FullWidth="true"
                       OnClick="OpenCreateDialog">
                Add Category
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-0" />
}
<MudTable @ref="_table"
          ServerData="LoadDataAsync"
          Dense="true"
          Hover="true"
          Loading="false">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Description</MudTh>
            <MudTh>Product Count</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" Class="mr-2" />
                    <MudText Typo="Typo.body1"><b>@context.Name</b></MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="Description">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @(string.IsNullOrEmpty(context.Description) ? "No description" : context.Description)
                </MudText>
            </MudTd>
            <MudTd DataLabel="Product Count">
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.ProductCount > 0 ? Color.Info : Color.Default)">
                    @context.ProductCount
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Color="Color.Primary"
                               Size="Size.Small"
                               OnClick="() => OpenEditDialog(context)" />
                <MudTooltip Text="@GetDeleteTooltip(context)"
                            Disabled="@CanDeleteCategory(context)">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   Disabled="@(!CanDeleteCategory(context))"
                                   OnClick="() => DeleteCategory(context.Id)" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>

@code {
    private MudTable<CategoryDto>? _table;
    private bool _loading = false;
    private string _searchString = string.Empty;

    private bool CanDeleteCategory(CategoryDto category)
        => category.ProductCount == 0 && category.Children.Count == 0;

    private string GetDeleteTooltip(CategoryDto category)
    {
        var reasons = new List<string>();

        if (category.ProductCount > 0)
        {
            var word = category.ProductCount == 1 ? "product" : "products";
            reasons.Add($"{category.ProductCount} {word}");
        }

        if (category.Children.Count > 0)
        {
            var word = category.Children.Count == 1 ? "subcategory" : "subcategories";
            reasons.Add($"{category.Children.Count} {word}");
        }

        return reasons.Count > 0
            ? $"Cannot delete: has {string.Join(" and ", reasons)}"
            : string.Empty;
    }

    private async Task<TableData<CategoryDto>> LoadDataAsync(TableState state, CancellationToken token)
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var response = await CategoryService.GetCategoriesAsync(
                page: state.Page + 1,
                pageSize: state.PageSize,
                search: string.IsNullOrWhiteSpace(_searchString) ? null : _searchString
            );

            if (response?.Success == true && response.Data != null)
            {
                return new TableData<CategoryDto>
                {
                    Items = response.Data.Items,
                    TotalItems = response.Data.TotalCount
                };
            }

            Snackbar.Add(response?.Error?.Message ?? "Failed to load categories", Severity.Error);
            return new TableData<CategoryDto> { Items = new List<CategoryDto>(), TotalItems = 0 };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading categories: {ex.Message}", Severity.Error);
            return new TableData<CategoryDto> { Items = new List<CategoryDto>(), TotalItems = 0 };
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task OnSearchChanged()
    {
        await _table!.ReloadServerData();
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<CategoryDialog>("Create Category");
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await _table!.ReloadServerData();
            Snackbar.Add("Category created successfully", Severity.Success);
        }
    }

    private async Task OpenEditDialog(CategoryDto category)
    {
        var parameters = new DialogParameters
        {
            ["Category"] = category
        };

        var dialog = await DialogService.ShowAsync<CategoryDialog>("Edit Category", parameters);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await _table!.ReloadServerData();
            Snackbar.Add("Category updated successfully", Severity.Success);
        }
    }

    private async Task DeleteCategory(Guid id)
    {
        var parameters = new DialogParameters
        {
            ["ContentText"] = "Are you sure you want to delete this category? This action cannot be undone.",
            ["ButtonText"] = "Delete",
            ["Color"] = Color.Error
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Category", parameters);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            try
            {
                var response = await CategoryService.DeleteCategoryAsync(id);
                if (response?.Success == true)
                {
                    await _table!.ReloadServerData();
                    Snackbar.Add("Category deleted successfully", Severity.Success);
                }
                else
                {
                    Snackbar.Add(response?.Error?.Message ?? "Failed to delete category", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting category: {ex.Message}", Severity.Error);
            }
        }
    }
}
